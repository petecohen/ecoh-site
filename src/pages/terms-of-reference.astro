---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Terms of Reference - ECOH">
  <div class="page-content">
    <div class="container">
      <h1>Terms of Reference</h1>
      <p>
        The ECOH Community of Practice operates under a clear Terms of Reference that outlines our
        purpose, structure, and selection process for participants.
      </p>
      <div class="cta">
        <a href="#" class="button">View Full Terms of Reference →</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .page-content {
    padding: 4rem 2rem;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
  }

  h1 {
    color: #2563eb;
    font-size: 2.5rem;
    margin-bottom: 2rem;
  }

  p {
    margin-bottom: 2rem;
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .cta {
    margin-top: 3rem;
  }

  .button {
    display: inline-block;
    background: #2563eb;
    color: white;
    padding: 1rem 2rem;
    border-radius: 6px;
    text-decoration: none;
    font-size: 1.1rem;
    transition: background 0.3s;
  }

  .button:hover {
    background: #1d4ed8;
  }
</style>
