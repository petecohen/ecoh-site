---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact - ECOH">
  <div class="page-content">
    <div class="container">
      <h1>Contact</h1>
      <p>For more information about ECOH, contact:</p>

      <div class="contact-cards">
        <div class="contact-card">
          <h3>Pete Cohen</h3>
          <a href="mailto:pete.cohen@rmit.edu.au">pete.cohen@rmit.edu.au</a>
        </div>

        <div class="contact-card">
          <h3>Antony McMullen</h3>
          <a href="mailto:antonymcmullen@bonds.coop">antonymcmullen@bonds.coop</a>
        </div>

        <div class="contact-card">
          <h3>Yolanda van Gellecum</h3>
          <a href="mailto:yolanda@bonds.coop">yolanda@bonds.coop</a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .page-content {
    padding: 4rem 2rem;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
  }

  h1 {
    color: #2563eb;
    font-size: 2.5rem;
    margin-bottom: 2rem;
  }

  p {
    margin-bottom: 3rem;
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .contact-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }

  .contact-card {
    background: white;
    border: 2px solid #e5e7eb;
    border-radius: 8px;
    padding: 2rem;
    transition: all 0.3s;
  }

  .contact-card:hover {
    border-color: #2563eb;
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.1);
  }

  .contact-card h3 {
    color: #333;
    font-size: 1.3rem;
    margin-bottom: 0.75rem;
  }

  .contact-card a {
    color: #2563eb;
    text-decoration: none;
    font-size: 1rem;
  }

  .contact-card a:hover {
    text-decoration: underline;
  }
</style>
