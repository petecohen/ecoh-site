---
// Standalone white paper microsite — does not use the main ECOH Layout,
// so it can carry its own look and feel. Purely additive.
const pdfUrl =
  "https://public-pc.s3.amazonaws.com/Employee_and_Community_Ownership_in_Australia_Pre-release_Summary_2026-04-19.pdf";
const launchVideo = "https://www.youtube-nocookie.com/embed/Q8u_fkZKxLo";
const nuttallVideo = "https://youtu.be/hlQ-hCWJHag";
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Employee and Community Ownership in Australia — ECOH White Paper</title>
    <meta
      name="description"
      content="An ECOH white paper making the case for employee and community ownership as underutilised tools for business succession and worker wealth-building in Australia."
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Employee and Community Ownership in Australia" />
    <meta
      property="og:description"
      content="An ECOH white paper on employee and community ownership in Australia. Pre-release summary available now; full paper May 2026."
    />
  </head>
  <body>
    <header class="topbar">
      <div class="topbar-inner">
        <a href="/" class="brand">ECOH</a>
        <a href="/" class="back-link">← Back to the main site</a>
      </div>
    </header>

    <main>
      <!-- HERO -->
      <section class="hero">
        <div class="hero-inner">
          <div class="hero-text">
            <p class="eyebrow">ECOH White Paper</p>
            <h1>Employee and Community Ownership in Australia</h1>
            <p class="lede">
              The case for employee and community ownership as underutilised tools for business
              succession and worker wealth-building in Australia.
            </p>
            <p class="byline">
              Pete Cohen, Antony McMullen &amp; Yolanda van Gellecum · Employee and Community
              Ownership Hub
            </p>
            <div class="hero-actions">
              <a class="btn btn-primary" href={pdfUrl} target="_blank" rel="noopener">
                Read the pre-release summary (PDF)
              </a>
              <a class="btn btn-ghost" href="#launch">Watch the launch</a>
            </div>
            <p class="hero-note">
              Pre-release summary and selected excerpts available now. Full white paper expected
              May 2026.
            </p>
          </div>

          <!-- CSS cover mockup -->
          <div class="hero-cover" aria-hidden="true">
            <div class="cover-card">
              <span class="cover-tag">Pre-release summary</span>
              <p class="cover-org">ECOH</p>
              <p class="cover-title">Employee and Community Ownership in Australia</p>
              <p class="cover-sub">Executive summary &amp; selected excerpts</p>
              <div class="cover-rule"></div>
              <p class="cover-authors">
                Pete Cohen · Antony McMullen · Yolanda van Gellecum
              </p>
              <p class="cover-date">April 2026</p>
            </div>
          </div>
        </div>
      </section>

      <!-- PREMISE -->
      <section class="section section-paper">
        <div class="wrap">
          <p class="section-eyebrow">The premise</p>
          <h2>The economy is no longer working well for many Australians.</h2>
          <p>
            Wages have not kept pace with productivity, wealth has become more concentrated,
            housing is increasingly out of reach, and communities find themselves with diminishing
            say over the economic decisions that shape their daily lives. Artificial intelligence is
            moving through the professions faster than almost anyone anticipated, leaving a
            generation of capable knowledge workers searching for a viable economic future.
          </p>
          <p>
            At the same time, a wave of business owners is approaching retirement without a clear
            succession path. Too many good businesses are wound up or sold offshore when they could
            instead pass into the hands of the people who built them and the communities they serve.
          </p>
          <blockquote class="pull">
            Employee and community ownership are underutilised tools for business succession and
            worker wealth-building in Australia.
          </blockquote>
        </div>
      </section>

      <!-- WHAT THE PAPER COVERS -->
      <section class="section">
        <div class="wrap">
          <p class="section-eyebrow">Inside the paper</p>
          <h2>What the white paper covers</h2>
          <div class="cover-grid">
            <article class="topic">
              <span class="topic-num">01</span>
              <h3>Australia's ownership opportunity</h3>
              <p>The succession challenge, and why ownership structure matters.</p>
            </article>
            <article class="topic">
              <span class="topic-num">02</span>
              <h3>What works</h3>
              <p>Practical models — EOTs, worker cooperatives, and community ownership structures.</p>
            </article>
            <article class="topic">
              <span class="topic-num">03</span>
              <h3>Australian voices</h3>
              <p>Case studies and insights from practitioners across the country.</p>
            </article>
            <article class="topic">
              <span class="topic-num">04</span>
              <h3>Barriers holding Australia back</h3>
              <p>Regulatory, tax, and knowledge gaps that slow adoption.</p>
            </article>
            <article class="topic">
              <span class="topic-num">05</span>
              <h3>International lessons</h3>
              <p>What other countries are doing — the UK, US, Canada, and Denmark.</p>
            </article>
            <article class="topic">
              <span class="topic-num">06</span>
              <h3>The path forward</h3>
              <p>Concrete recommendations for government, advisors, and business owners.</p>
            </article>
          </div>
        </div>
      </section>

      <!-- NOT NEUTRAL -->
      <section class="section section-paper">
        <div class="wrap narrow">
          <div class="stance">
            <h3>We are not neutral observers</h3>
            <p>
              This is an advocacy paper. It presents substantial evidence, and it is honest about
              where it stands: we want to see more employee and community-owned businesses in
              Australia, and we want government policy to make that easier. The paper is authored by
              practitioners, researchers, and advocates who have taken part in ECOH's 2025 Community
              of Practice sessions.
            </p>
          </div>
        </div>
      </section>

      <!-- LAUNCH -->
      <section id="launch" class="section">
        <div class="wrap">
          <p class="section-eyebrow">From the launch</p>
          <h2>Launched at The Kelvin Club, Melbourne</h2>
          <p>
            The white paper was launched on 21 April 2026. A recording of the evening — including
            the panel discussion — is available below.
          </p>
          <div class="video">
            <iframe
              src={launchVideo}
              title="ECOH White Paper launch event"
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
          <div class="launch-photos">
            <figure class="landscape">
              <img src="/images/launch/ecoh-launch-1.jpg" alt="Panel discussion at the ECOH white paper launch, The Kelvin Club, Melbourne" loading="lazy" width="1000" height="667" />
            </figure>
            <figure class="portrait">
              <img src="/images/launch/ecoh-launch-2.jpg" alt="A speaker at the ECOH white paper launch, The Kelvin Club, Melbourne" loading="lazy" width="667" height="1000" />
            </figure>
          </div>
          <p class="photo-credit">Photos from the launch event, 21 April 2026. Photo credit: Eric Algra.</p>
        </div>
      </section>

      <!-- FURTHER VIEWING -->
      <section class="section section-paper">
        <div class="wrap narrow">
          <div class="callout">
            <h4>Further viewing: Graeme Nuttall on employee ownership</h4>
            <p>
              An earlier presentation from Graeme Nuttall, a leading international voice on employee
              ownership trusts.
            </p>
            <p>
              <a href={nuttallVideo} target="_blank" rel="noopener" class="callout-link">
                Watch on YouTube →
              </a>
            </p>
          </div>
        </div>
      </section>

      <!-- AUTHORS -->
      <section class="section">
        <div class="wrap">
          <p class="section-eyebrow">The authors</p>
          <h2>Written by</h2>
          <div class="authors">
            <div class="author">
              <h3>Pete Cohen</h3>
              <p>Co-steward, ECOH · RMIT FORWARD</p>
            </div>
            <div class="author">
              <h3>Antony McMullen</h3>
              <p>Co-steward, ECOH · Co-operative Bonds</p>
            </div>
            <div class="author">
              <h3>Yolanda van Gellecum</h3>
              <p>Co-steward, ECOH · Co-operative Bonds</p>
            </div>
          </div>
        </div>
      </section>

      <!-- GET THE PAPER -->
      <section class="section section-cta">
        <div class="wrap narrow center">
          <h2>Read the pre-release summary</h2>
          <p>
            The executive summary and selected excerpts are available now, free to read. The full
            white paper is expected in May 2026.
          </p>
          <div class="cta-actions">
            <a class="btn btn-primary" href={pdfUrl} target="_blank" rel="noopener">
              Download the summary (PDF)
            </a>
            <a class="btn btn-ghost" href="/#contact">Get in touch</a>
          </div>
          <p class="cta-note">
            If you'd like to stay informed about the full paper's release or contribute insights,
            we'd love to hear from you.
          </p>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="wrap center">
        <p class="footer-brand">ECOH</p>
        <p>© 2026 Employee and Community Ownership Hub (ECOH)</p>
        <p class="footer-fine">
          Stewarded by RMIT FORWARD, Co-operative Bonds, Employee Ownership Australia, and the
          Business Council of Co-operatives and Mutuals
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --navy: #0f2744;
    --navy-2: #1e3a5f;
    --blue: #2563eb;
    --blue-light: #eff6ff;
    --ink: #1f2937;
    --muted: #5b6472;
    --paper: #f7f5f1;
    --line: #e6e3dd;
    --serif: Georgia, 'Times New Roman', serif;
    --sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: var(--sans); color: var(--ink); line-height: 1.65; background: #fff; }
  a { color: var(--blue); }
  img { max-width: 100%; display: block; }

  /* Layout helpers */
  .wrap { max-width: 1080px; margin: 0 auto; padding: 0 2rem; }
  .wrap.narrow { max-width: 760px; }
  .center { text-align: center; }

  .section { padding: 4.5rem 0; background: #fff; }
  .section-paper { background: var(--paper); }

  .section-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--blue);
    margin-bottom: 0.6rem;
  }

  h2 { font-family: var(--serif); font-size: clamp(1.7rem, 3.2vw, 2.4rem); line-height: 1.2; color: var(--navy); margin-bottom: 1.1rem; font-weight: 600; }
  h3 { font-family: var(--serif); font-size: 1.25rem; color: var(--navy); margin-bottom: 0.5rem; font-weight: 600; }
  .section p { font-size: 1.05rem; color: var(--ink); margin-bottom: 1rem; max-width: 68ch; }
  .section-paper .section p, .center p { margin-left: auto; margin-right: auto; }

  /* Topbar */
  .topbar { background: var(--navy); }
  .topbar-inner { max-width: 1080px; margin: 0 auto; padding: 0.75rem 2rem; display: flex; justify-content: space-between; align-items: center; }
  .brand { font-weight: 800; letter-spacing: 0.04em; color: #fff; text-decoration: none; font-size: 1.15rem; }
  .back-link { color: rgba(255,255,255,0.8); text-decoration: none; font-size: 0.9rem; }
  .back-link:hover { color: #fff; }

  /* Hero */
  .hero { background: linear-gradient(135deg, var(--navy) 0%, var(--navy-2) 100%); color: #fff; padding: 4.5rem 0; }
  .hero-inner { max-width: 1080px; margin: 0 auto; padding: 0 2rem; display: grid; grid-template-columns: 1.15fr 0.85fr; gap: 3rem; align-items: center; }
  .eyebrow { text-transform: uppercase; letter-spacing: 0.14em; font-size: 0.8rem; font-weight: 700; color: #9ec5ff; margin-bottom: 0.9rem; }
  .hero h1 { font-family: var(--serif); font-size: clamp(2rem, 4.5vw, 3rem); line-height: 1.12; font-weight: 600; margin-bottom: 1.1rem; }
  .lede { font-size: 1.2rem; line-height: 1.55; color: rgba(255,255,255,0.92); margin-bottom: 1.1rem; }
  .byline { font-size: 0.95rem; color: rgba(255,255,255,0.72); margin-bottom: 1.6rem; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-bottom: 1.1rem; }
  .hero-note { font-size: 0.9rem; color: rgba(255,255,255,0.7); }

  /* Buttons */
  .btn { display: inline-block; padding: 0.8rem 1.4rem; border-radius: 8px; font-weight: 600; font-size: 0.98rem; text-decoration: none; transition: transform 0.15s, background 0.2s, border-color 0.2s; }
  .btn:hover { transform: translateY(-1px); }
  .btn-primary { background: var(--blue); color: #fff; }
  .btn-primary:hover { background: #1d4fd7; }
  .btn-ghost { background: transparent; color: #fff; border: 1.5px solid rgba(255,255,255,0.45); }
  .btn-ghost:hover { border-color: #fff; background: rgba(255,255,255,0.08); }
  .section-cta .btn-ghost { color: #fff; }

  /* Hero cover mockup */
  .hero-cover { display: flex; justify-content: center; }
  .cover-card { position: relative; width: 300px; aspect-ratio: 3 / 4; background: linear-gradient(160deg, #fbfaf7 0%, #eef1f6 100%); border-radius: 6px; box-shadow: 0 24px 50px rgba(0,0,0,0.35); padding: 2rem 1.6rem; border-top: 6px solid var(--blue); display: flex; flex-direction: column; }
  .cover-tag { position: absolute; top: 1.1rem; right: -0.4rem; background: var(--blue); color: #fff; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 0.3rem 0.7rem; border-radius: 3px; box-shadow: 0 4px 10px rgba(0,0,0,0.2); }
  .cover-org { font-weight: 800; letter-spacing: 0.08em; color: var(--navy); font-size: 0.95rem; margin-bottom: 2.2rem; }
  .cover-title { font-family: var(--serif); font-size: 1.35rem; line-height: 1.25; color: var(--navy); font-weight: 600; }
  .cover-sub { font-size: 0.82rem; color: var(--muted); margin-top: 0.5rem; }
  .cover-rule { height: 2px; background: var(--blue); width: 44px; margin: 1.4rem 0; }
  .cover-authors { font-size: 0.78rem; color: var(--ink); margin-top: auto; }
  .cover-date { font-size: 0.78rem; color: var(--muted); margin-top: 0.3rem; }

  /* Pull quote */
  .pull { font-family: var(--serif); font-size: clamp(1.4rem, 2.6vw, 1.85rem); line-height: 1.35; color: var(--navy); border-left: 4px solid var(--blue); padding: 0.4rem 0 0.4rem 1.4rem; margin-top: 2rem; max-width: 60ch; font-style: italic; }

  /* Topic grid */
  .cover-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.4rem; margin-top: 2rem; }
  .topic { background: #fff; border: 1px solid var(--line); border-radius: 10px; padding: 1.6rem 1.5rem; transition: box-shadow 0.2s, transform 0.15s; }
  .topic:hover { box-shadow: 0 10px 26px rgba(15,39,68,0.08); transform: translateY(-2px); }
  .topic-num { font-family: var(--serif); font-size: 0.95rem; font-weight: 700; color: var(--blue); }
  .topic h3 { margin-top: 0.4rem; }
  .topic p { font-size: 0.98rem; color: var(--muted); margin: 0; }

  /* Stance */
  .stance { background: #fff; border: 1px solid var(--line); border-left: 4px solid var(--blue); border-radius: 8px; padding: 1.8rem 2rem; }
  .stance h3 { margin-bottom: 0.6rem; }
  .stance p { margin: 0; }

  /* Video */
  .video { position: relative; width: 100%; aspect-ratio: 16 / 9; margin: 1.8rem 0; border-radius: 10px; overflow: hidden; box-shadow: 0 12px 30px rgba(15,39,68,0.18); background: #000; }
  .video iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }

  /* Launch photos — aspect-ratio-proportional flex so heights match */
  .launch-photos { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 0.5rem; align-items: flex-start; }
  .launch-photos figure { margin: 0; min-width: 0; }
  .launch-photos figure.landscape { flex: 1.499 1 0; }
  .launch-photos figure.portrait { flex: 0.667 1 0; }
  .launch-photos img { width: 100%; height: auto; border-radius: 8px; box-shadow: 0 2px 10px rgba(15,39,68,0.1); }
  .photo-credit { font-size: 0.85rem; color: var(--muted); font-style: italic; margin-top: 0.75rem; }
  @media (max-width: 600px) {
    .launch-photos figure.landscape, .launch-photos figure.portrait { flex: 1 1 100%; }
  }

  /* Callout */
  .callout { background: var(--blue-light); border-left: 4px solid var(--blue); border-radius: 6px; padding: 1.5rem 1.75rem; }
  .callout h4 { font-family: var(--serif); color: var(--navy); font-size: 1.15rem; margin-bottom: 0.6rem; }
  .callout p { font-size: 1rem; margin-bottom: 0.6rem; max-width: none; }
  .callout p:last-child { margin-bottom: 0; }
  .callout-link { font-weight: 600; text-decoration: none; }
  .callout-link:hover { text-decoration: underline; }

  /* Authors */
  .authors { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.4rem; margin-top: 2rem; }
  .author { background: var(--paper); border-radius: 10px; padding: 1.4rem 1.5rem; }
  .author h3 { margin-bottom: 0.3rem; }
  .author p { font-size: 0.92rem; color: var(--muted); margin: 0; }

  /* CTA section */
  .section-cta { background: linear-gradient(135deg, var(--navy) 0%, var(--navy-2) 100%); color: #fff; padding: 4.5rem 0; }
  .section-cta h2 { color: #fff; }
  .section-cta p { color: rgba(255,255,255,0.9); }
  .cta-actions { display: flex; flex-wrap: wrap; gap: 0.8rem; justify-content: center; margin: 1.6rem 0 1rem; }
  .cta-note { font-size: 0.92rem; color: rgba(255,255,255,0.72) !important; }

  /* Footer */
  .site-footer { background: var(--navy); color: rgba(255,255,255,0.75); padding: 2.5rem 0; }
  .footer-brand { font-weight: 800; letter-spacing: 0.06em; color: #fff; font-size: 1.1rem; margin-bottom: 0.5rem; }
  .site-footer p { margin: 0.25rem 0; font-size: 0.88rem; }
  .footer-fine { color: rgba(255,255,255,0.55); max-width: 60ch; margin: 0.5rem auto 0; }

  /* Responsive */
  @media (max-width: 860px) {
    .hero-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .hero-cover { order: -1; }
    .cover-card { width: 260px; }
  }
  @media (max-width: 560px) {
    .wrap, .hero-inner, .topbar-inner { padding-left: 1.25rem; padding-right: 1.25rem; }
    .section { padding: 3.25rem 0; }
    .hero-actions .btn, .cta-actions .btn { width: 100%; text-align: center; }
  }
</style>
